	id="my-data"
	type="application/json"
	set:html={JSON.stringify(miniRoad)}
	is:inline
/>
<Layout />

<script>
	import * as THREE from "three";
	import { GLTFLoader } from "three/examples/jsm/Addons.js";

	const jsonDataElement = document.getElementById("my-data");
	const clientData = JSON.parse(jsonDataElement.innerText);
	const loader = new GLTFLoader();
	const scene = new THREE.Scene();
	scene.background = new THREE.Color(0xeeeeee);
	scene.fog = new THREE.Fog(0xeeeeee, 30, 200);
	const camera = new THREE.PerspectiveCamera(
		80,
		window.innerWidth / window.innerHeight,
		0.1,
		190,
	);

	const renderer = new THREE.WebGLRenderer({ antialias: true });
	renderer.setSize(window.innerWidth, window.innerHeight);
	const container = document.getElementById("canvas-container");
	container?.appendChild(renderer.domElement);

	// 	const dashShaderMaterial = new THREE.ShaderMaterial({
	// 		uniforms: {
	// 			uDashSize: { value: 0.4 }, // Number of dashes across the surface
	// 			uGapSize: { value: 0.4 }, // Ratio of dash to gap (0.0 to 1.0)
	// 			stripeColor: { value: new THREE.Color(0xeeeeee) },
	// 			roadColor: { value: new THREE.Color(0xffffff) },
	// 			uColor: { value: new THREE.Color(0xff0000) },
	// 			uBlurStrength: { value: 0.05 }
	// 		},
	// 		vertexShader: `
	// 		    varying vec2 vUv;
	// 		    void main() {
	// 		      vUv = uv;
	// 		      gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
	// 		    }
	// 		  `,
	// 		fragmentShader: `
	//     uniform vec3 uColor;
	// 	uniform vec3 roadColor;
	// 	uniform vec3 stripeColor;
	//     uniform float uDashSize;
	//     uniform float uGapSize;
	// 	uniform float uBlurStrength; // How soft the edges are
	//     varying vec2 vUv;

	//     void main() {
	//       // Create repeating pattern along the Y axis
	//       float totalSize = uDashSize + uGapSize;
	//       float pos = mod(vUv.x * 20.0, totalSize); // Scale 10.0 adjusts frequency
	// 	  float thickness = 0.25;
	//       float mask = smoothstep(1.0 - thickness, 1.0 + thickness, pos);

	// 	  float horizStripeThreshold = 0.1; // Stripes are within 10% of the edges
	//           float maskY = smoothstep(horizStripeThreshold - uBlurStrength, horizStripeThreshold, vUv.y) * (1.0 - smoothstep(1.0 - horizStripeThreshold, 1.0 - horizStripeThreshold + uBlurStrength, vUv.y));
	// float dashedMaskY = smoothstep(0.1, 0.1 + uBlurStrength, abs(vUv.y - 0.5));

	// float finalMask = mask * dashedMaskY;

	// 	  vec3 color = roadColor;
	// 	  if (vUv.y > 0.7 || vUv.y < 0.3 ) {
	// 		color = stripeColor;
	// 		// Discard pixels in the "gap" to make them transparent
	// 		} else {
	// 			color = mix(roadColor, stripeColor, mask);
	// 			if (pos > uDashSize) color = stripeColor;
	// 	}

	//       // Draw the dash (centered horizontally)

	//       if ((vUv.y > 0.51 && vUv.y < 0.7) || (vUv.y < 0.49 && vUv.y > 0.3) ) color = roadColor;
	//       gl_FragColor = vec4(color, 1.0);
	//     }
	//   `,
	// 		side: THREE.DoubleSide, // So we can see the inside of the dashed mesh
	// 	});

	const ribbonWidth = 50;
	const stripeWidth = 1;
	const stripeBlur = stripeWidth / ribbonWidth / 20;
	console.log(stripeBlur);
	const dashShaderMaterial = new THREE.ShaderMaterial({
		uniforms: {
			uRoadWidth: { value: 20.0 },
			uStripeWidth: { value: stripeWidth / ribbonWidth },
			uBlur: { value: stripeBlur },
			uRepeatCount: { value: 20.0 },
			uDashBlur: { value: 0.1 },
			uDashSize: { value: 0.4 }, // Length of the dash segment (relative to U)
			uGapSize: { value: 0.2 }, // Length of the gap segment (relative to U)
			uBlurStrength: { value: 0.05 }, // <--- NEW: Amount of edge blur (0.0 to 0.1+)
			stripeColor: { value: new THREE.Color(0xeeeeee) }, // Dashes/Stripes
			roadColor: { value: new THREE.Color(0xffffff) }, // Main road surface
		},
		vertexShader: `
      varying vec2 vUv;
varying vec3 vNormal;
varying vec3 vViewPosition;

void main() {
    vUv = uv;
    vec4 worldPosition = modelMatrix * vec4(position, 1.0);
    vNormal = normalize(normalMatrix * normal);
    vViewPosition = normalize(cameraPosition - worldPosition.xyz);
    
    gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
}
    `,
		fragmentShader: `
		varying vec2 vUv;
varying vec3 vNormal;
varying vec3 vViewPosition;

uniform vec3 roadColor;
uniform vec3 stripeColor;
uniform float uRoadWidth;
uniform float uStripeWidth; // e.g., 0.1 for 10% of the road width
uniform float uBlur;        // e.g., 0.02 for the edge softness
uniform float uRepeatCount;
uniform float uDashSize;
uniform float uDashBlur;
uniform float uGapSize;
uniform float uBlurStrength;

void main() {
    float totalCycle = uDashSize + uGapSize;
    float repeatedU = mod(vUv.x * uRepeatCount, totalCycle);
    float dashMask = smoothstep(0.0, uDashBlur, repeatedU) * (1.0 - smoothstep(uDashSize - uDashBlur, uDashSize, repeatedU));

    float distanceFromCenter = abs(vUv.y - 0.5);
    float halfWidth = uStripeWidth * 0.5;
    float roadMask = 1.0 - smoothstep(halfWidth - uBlur, halfWidth + uBlur, distanceFromCenter);
	// float roadMask = smoothstep(0.45, 0.47, vUv.y) * (1.0 - smoothstep( 0.53, 0.55, vUv.y)) ;

	dashMask = dashMask * roadMask;

	
//       if ((vUv.y > 0.51 && vUv.y < 0.7) || (vUv.y < 0.49 && vUv.y > 0.3) ) color = roadColor;
	//  float dashMask = smoothstep(0.0, uBlurStrength, repeatedU) * (1.0 - smoothstep(uDashSize - uBlurStrength, uDashSize, repeatedU));

    // 2. EDGE LOGIC (Following the road's width)
    // This creates a mask that is 1.0 in the center and 0.0 at the road shoulders
    

    // 3. FRESNEL LOGIC (The 3D "Mesh" Blur)
    // This blurs the edges of the geometry relative to your eyes
    float fresnel = pow(1.0 - clamp(dot(vNormal, vViewPosition), 0.0, 1.0), 200.0);

    // 4. MERGE EVERYTHING
    // We mix colors based on the dashMask, then fade the whole thing by the road edges AND Fresnel
    vec3 finalColor = mix(roadColor, stripeColor, dashMask);


	float edgeMask =smoothstep(0.22, 0.25, vUv.y) * (1.0 - smoothstep(0.8,  0.82, vUv.y));
    finalColor = finalColor * mix(stripeColor, roadColor, edgeMask);
    // Combine the masks: Road Width + Fresnel
    // float finalAlpha = roadEdgeMask * fresnel;




	float outerEdgeMask = smoothstep(0.0, uBlurStrength, vUv.y) * (1.0 - smoothstep(1.0 - uBlurStrength, 1.0, vUv.y));
    gl_FragColor = vec4(finalColor, outerEdgeMask);
}
    `,
		side: THREE.DoubleSide,
		transparent: true,
	});
	const gltf = loader.load("/miniroad.glb", (obj) => {
		const model = obj.scene;
		model.traverse((child) => {
			if (child.isMesh) {
				child.material = dashShaderMaterial;
				// Optionally enable shadows
				child.castShadow = true;
				child.receiveShadow = true;
			}
		});

		// scene.add(model);
	});

	const width = 100000000000;
	const height = 2000;
	const widthSegments = 1000; // Optional, default is 1
	const heightSegments = 1000; // Optional, default is 1
	const geometry2 = new THREE.PlaneGeometry(
		width,
		height,
		widthSegments,
		heightSegments,
	);
	const material2 = new THREE.MeshBasicMaterial({
		color: 0xcccccc, // Green color
		side: THREE.DoubleSide, // Makes the plane visible from both sides
	});
	const plane = new THREE.Mesh(geometry2, material2);
	plane.rotation.x = Math.PI / 2;
	plane.position.y -= 0.4;
	scene.add(plane);
	// const controls = new OrbitControls(camera, renderer.domElement);
	// controls.enableDamping = true;

	const vectorData = clientData.map(
		(data: any, i) => new THREE.Vector3(data[0], data[2], -data[1]),
	);
	console.log(vectorData);
	const geometry = new THREE.BufferGeometry().setFromPoints(vectorData);
	const material = new THREE.LineBasicMaterial({ color: 0xff0000 });
	const line = new THREE.Line(geometry, material);
	// scene.add(line);

	// var ls = 200; // length segments
	// var curve = new THREE.CatmullRomCurve3(vectorData);
	// var points = curve.getPoints(ls);
	// var curveGeometry = new THREE.BufferGeometry().setFromPoints(points);
	// var curveMaterial = new THREE.LineBasicMaterial({ color: 0xffffff });
	// var curveLine = new THREE.Line(curveGeometry, curveMaterial);
	// scene.add(curveLine);

	// const curve = new THREE.CatmullRomCurve3(vectorData);
	const curve = new THREE.CatmullRomCurve3(
		vectorData,
		false,
		"catmullrom",
		0.75,
	);

	console.log(curve);
	const ribbonGeom = createCurveRibbon(curve, ribbonWidth, 100);
	const ribbonMesh = new THREE.Mesh(ribbonGeom, dashShaderMaterial);
	scene.add(ribbonMesh);

	// 1. Create a Tube Mesh (The "Track")
	const tubeGeometry = new THREE.TubeGeometry(curve, 100, 0.2, 8, false);
	const tubeMaterial = new THREE.MeshStandardMaterial({
		color: 0x444444,
		wireframe: true,
		transparent: true,
		opacity: 0.3,
	});
	const tubeMesh = new THREE.Mesh(tubeGeometry, tubeMaterial);
	// scene.add(tubeMesh);

	// 2. Create a solid Line (The "Centerline")
	const points = curve.getPoints(200); // Higher number = smoother visual line
	const lineGeometry = new THREE.BufferGeometry().setFromPoints(points);
	const lineMaterial = new THREE.LineBasicMaterial({ color: 0xff0000 });
	const curveLine = new THREE.Line(lineGeometry, lineMaterial);
	// scene.add(curveLine);

	const baseFOV = 45;
	const maxFOV = 70;
	let currentFOV = baseFOV;

	function createCurveRibbon(curve, width = 2, segments = 64) {
		const points = curve.getPoints(segments);
		const vertices = [];
		const uvs = []; // <--- New UV array
		const indices = [];
		const up = new THREE.Vector3(0, 1, 0);

		for (let i = 0; i <= segments; i++) {
			const t = i / segments;
			const point = points[i];
			const tangent = curve.getTangentAt(t);

			const side = new THREE.Vector3().crossVectors(tangent, up).normalize();

			const leftPos = new THREE.Vector3()
				.copy(point)
				.addScaledVector(side, width / 2);
			const rightPos = new THREE.Vector3()
				.copy(point)
				.addScaledVector(side, -width / 2);

			vertices.push(leftPos.x, leftPos.y, leftPos.z);
			vertices.push(rightPos.x, rightPos.y, rightPos.z);

			// --- Generate UVs ---
			// U is the progress along the curve (0 to 1)
			// V is the width (0 for left, 1 for right)
			uvs.push(t, 0); // Left vertex UV
			uvs.push(t, 1); // Right vertex UV

			if (i < segments) {
				const a = i * 2;
				const b = i * 2 + 1;
				const c = (i + 1) * 2;
				const d = (i + 1) * 2 + 1;

				indices.push(a, b, c);
				indices.push(b, d, c);
			}
		}

		const geometry = new THREE.BufferGeometry();
		geometry.setAttribute(
			"position",
			new THREE.Float32BufferAttribute(vertices, 3),
		);

		// --- Add the UV attribute ---
		geometry.setAttribute("uv", new THREE.Float32BufferAttribute(uvs, 2));

		geometry.setIndex(indices);
		geometry.computeVertexNormals();

		return geometry;
	}

	const obj3d = new THREE.Object3D();
	camera.position.set(0, 2, -5);
	obj3d.add(camera);
	let fraction = 0; // Progress from 0 to 1
	const up = new THREE.Vector3(0, 1, 0);
	const axis = new THREE.Vector3();

	// 1. Setup (Place these OUTSIDE the animate function)
	const clock = new THREE.Clock();
	const tempVec = new THREE.Vector3();
	const smoothedTangent = new THREE.Vector3();
	const smoothedPosition = new THREE.Vector3();

	const guideGeometry = new THREE.SphereGeometry(0.9, 16, 16);
	const guideMaterial = new THREE.MeshBasicMaterial({
		color: 0x00ff00,
		noDepthTest: true,
	});
	const targetSphere = new THREE.Mesh(guideGeometry, guideMaterial);
	targetSphere.renderOrder = 999; // Make sure it's always visible
	scene.add(targetSphere);

	function animate() {
		requestAnimationFrame(animate);

		// Get time elapsed since last frame (Delta)
		const delta = clock.getDelta();

		// 2. Consistent Movement Speed
		// 0.05 is the speed factor; adjust as needed
		fraction += delta * 0.05;
		if (fraction > 1) fraction = 0;

		// 3. Get raw path data
		const rawPosition = curve.getPoint(fraction);
		const rawTangent = curve.getTangent(fraction);
		const rawLookAhead = Math.min(fraction + 0.05, 1);
		const rawTargetPos = curve.getPoint(rawLookAhead);

		targetSphere.position.copy(rawTargetPos);

		// 4. THE SMOOTHER: Linear Interpolation (lerp)
		// 0.1 (10%) follows closely, 0.02 (2%) follows very loosely/smoothly
		const smoothingFactor = 0.02;
		smoothedPosition.lerp(rawPosition, smoothingFactor);
		smoothedTangent.lerp(rawTangent, smoothingFactor).normalize();

		// 5. Calculate Camera Offset
		// Position the camera 10 units behind the smoothed position
		const offset = smoothedTangent.clone().multiplyScalar(-10);
		offset.y += 4; // Height offset

		camera.position.copy(smoothedPosition).add(offset);

		// 6. Look Ahead
		// We look at a point further down the smoothed tangent
		const lookTarget = tempVec
			.copy(smoothedPosition)
			.add(smoothedTangent.clone().multiplyScalar(15));
		camera.lookAt(lookTarget);

		// 7. Dynamic Banking (Optional)
		// To add a lean, we rotate the camera on its Z-axis (roll)
		const lookAhead = Math.min(fraction + 0.02, 1);
		const tan1 = curve.getTangent(fraction);
		const tan2 = curve.getTangent(lookAhead);
		const curvature = 1.0 - tan1.dot(tan2);
		const targetFOV = baseFOV + curvature * 800;
		const constrainedFOV = Math.min(targetFOV, maxFOV);
		currentFOV = THREE.MathUtils.lerp(currentFOV, constrainedFOV, 0.05);
		camera.fov = currentFOV;
		camera.updateProjectionMatrix();
		// Apply a subtle roll based on the curve intensity
		// camera.rotation.z = THREE.MathUtils.lerp(camera.rotation.z, side.y * 5, 0.05);

		// Lighting and Render
		renderer.render(scene, camera);
	}

	window.addEventListener("resize", () => {
		camera.aspect = window.innerWidth / window.innerHeight;
		camera.updateProjectionMatrix();
		renderer.setSize(window.innerWidth, window.innerHeight);
	});

	animate();
</script>
