---
import Layout from "../../layouts/Layout.astro";
import { segmentData } from "../../data/strava";
---

<script
	id="my-data"
	type="application/json"
	set:html={JSON.stringify(segmentData)}
	is:inline
/>
<Layout />

<script>
	import * as THREE from "three";
	import { ParametricGeometry } from "three/examples/jsm/Addons.js";
	import { OrbitControls } from "three/examples/jsm/Addons.js";
	import { GLTFExporter } from "three/examples/jsm/Addons.js";
	import { GLTFLoader } from "three/examples/jsm/Addons.js";

	const loader = new GLTFLoader();
	const scene = new THREE.Scene();
	scene.background = new THREE.Color(0xeeeeee);
	const camera = new THREE.PerspectiveCamera(
		70,
		window.innerWidth / window.innerHeight,
		0.1,
		1000,
	);
	camera.position.set(3, 5, -10);
	const renderer = new THREE.WebGLRenderer({ antialias: true });
	renderer.setSize(window.innerWidth, window.innerHeight);
	const container = document.getElementById("canvas-container");
	container?.appendChild(renderer.domElement);

	const dashShaderMaterial = new THREE.ShaderMaterial({
		uniforms: {
			uDashSize: { value: 0.4 }, // Number of dashes across the surface
			uGapSize: { value: 0.4 }, // Ratio of dash to gap (0.0 to 1.0)
			stripeColor: { value: new THREE.Color(0xeeeeee) },
			roadColor: { value: new THREE.Color(0xffffff) },
			uColor: { value: new THREE.Color(0xff0000) },
		},
		vertexShader: `
		    varying vec2 vUv;
		    void main() {
		      vUv = uv;
		      gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
		    }
		  `,
		fragmentShader: `
    uniform vec3 uColor;
	uniform vec3 roadColor;
	uniform vec3 stripeColor;
    uniform float uDashSize;
    uniform float uGapSize;
    varying vec2 vUv;

    void main() {
      // Create repeating pattern along the Y axis
      float totalSize = uDashSize + uGapSize;
      float pos = mod(vUv.x * 20.0, totalSize); // Scale 10.0 adjusts frequency
	  float thickness = 0.25; 
      float mask = smoothstep(1.0 - thickness, 1.0 + thickness, pos);

	  vec3 color = mix(roadColor, stripeColor, mask);

      // Discard pixels in the "gap" to make them transparent
      if (pos > uDashSize) color = stripeColor;

      // Draw the dash (centered horizontally)

      if (vUv.y > 0.502 || vUv.y < 0.498 ) color = roadColor;
      gl_FragColor = vec4(color, 1.0);
    }
  `,
		side: THREE.DoubleSide, // So we can see the inside of the dashed mesh
	});

	const gltf = loader.load("/road-centeruv.glb", (obj) => {
		const model = obj.scene;
		model.traverse((child) => {
			if (child.isMesh) {
				child.material = dashShaderMaterial;
				// Optionally enable shadows
				child.castShadow = true;
				child.receiveShadow = true;
			}
		});

		scene.add(model);
	});

	const controls = new OrbitControls(camera, renderer.domElement);
	controls.enableDamping = true;

	const ambientLight = new THREE.AmbientLight("white", 0.3);
	scene.add(ambientLight);

	var topLight = new THREE.DirectionalLight("white", 0 * 0.3);
	topLight.position.set(0, 0, 1);
	scene.add(topLight);

	var light = new THREE.DirectionalLight("white", 1);
	scene.add(light);

	function animate() {
		controls.update();
		requestAnimationFrame(animate);
		renderer.render(scene, camera);
	}

	// Handle Resizing
	window.addEventListener("resize", () => {
		camera.aspect = window.innerWidth / window.innerHeight;
		camera.updateProjectionMatrix();
		renderer.setSize(window.innerWidth, window.innerHeight);
	});

	animate();
</script>
