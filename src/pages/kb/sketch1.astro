---
import Layout from "../../layouts/Layout.astro";
---

<Layout />

<script>
	import * as THREE from "three";
	import { GLTFLoader } from "three/examples/jsm/Addons.js";
	import { DRACOLoader } from "three/addons/loaders/DRACOLoader.js";
	import { OrbitControls } from "three/examples/jsm/Addons.js";
	import { RoomEnvironment } from "three/addons/environments/RoomEnvironment.js";

	const scene = new THREE.Scene();
	scene.background = new THREE.Color("gainsboro");

	const texloader = new THREE.TextureLoader();

	const camera = new THREE.PerspectiveCamera(
		30,
		window.innerWidth / window.innerHeight,
		0.1,
		1000,
	);
	camera.position.set(0, 5, 10);
	camera.lookAt(scene.position);

	const loader = new GLTFLoader();
	const dracoLoader = new DRACOLoader();
	dracoLoader.setDecoderPath("https://www.gstatic.com/draco/v1/decoders/");
	loader.setDRACOLoader(dracoLoader);

	const renderer = new THREE.WebGLRenderer({ antialias: true });
	renderer.setSize(window.innerWidth, window.innerHeight);
	const container = document.getElementById("canvas-container");
	container?.appendChild(renderer.domElement);

	const environment = new RoomEnvironment();
	const pmremGenerator = new THREE.PMREMGenerator(renderer);
	const envMap = pmremGenerator.fromScene(environment).texture;
	scene.environment = envMap;

	const controls = new OrbitControls(camera, renderer.domElement);
	controls.enableDamping = true;

	const ambientLight = new THREE.AmbientLight("white", 0.3);
	scene.add(ambientLight);

	var topLight = new THREE.DirectionalLight("white", 0 * 0.3);
	topLight.position.set(0, 0, 1);
	scene.add(topLight);

	var light = new THREE.DirectionalLight("white", 1);
	scene.add(light);

	const count = 100; // Number of instances
	const dummy = new THREE.Object3D();

	const caseNormal = texloader.load("/3dprint.webp");
	caseNormal.repeat.set(0, 1);
	caseNormal.wrapS = caseNormal.wrapT = THREE.RepeatWrapping;

	loader.load("/kb-vent.glb", (gltf) => {
		let mesh;

		// 1. Extract the mesh from the GLTF scene
		gltf.scene.traverse((child) => {
			if (child.isMesh && !mesh) {
				mesh = child; // Grabbing the first mesh found
			}
		});

		if (mesh) {
			// 2. Create the InstancedMesh
			// We use the geometry and material from the loaded file
			const material = new THREE.MeshStandardMaterial({
				color: 0x121212,
				side: THREE.DoubleSide,
			});
			material.normalMap = caseNormal;

			const instancedMesh = new THREE.InstancedMesh(
				mesh.geometry,
				material,
				count,
			);

			// 3. Position each instance
			for (let i = 0; i < count; i++) {
				// Set random positions or a grid
				dummy.position.set(0.044 * i, 0, 0);

				dummy.updateMatrix();
				instancedMesh.setMatrixAt(i, dummy.matrix);
			}

			// Update the instance matrix to reflect the changes
			instancedMesh.instanceMatrix.needsUpdate = true;

			scene.add(instancedMesh);
		}
	});

	function animate() {
		controls.update();
		light.position.copy(camera.position);
		requestAnimationFrame(animate);
		renderer.render(scene, camera);
	}

	window.addEventListener("resize", () => {
		camera.aspect = window.innerWidth / window.innerHeight;
		camera.updateProjectionMatrix();
		renderer.setSize(window.innerWidth, window.innerHeight);
	});

	animate();
</script>
